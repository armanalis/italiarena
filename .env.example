# Public Supabase keys (safe for the browser). Get these from your Supabase project
# or ask a maintainer which values to use for contribution work.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fallback site URL for local dev and server-side email links. In production, set this
# to https://italiarena.com (not any *.vercel.app URL). Email confirmation and
# password-reset links always use https://italiarena.com/auth/callback outside
# localhost. In Supabase → Authentication → URL configuration, set Site URL to
# https://italiarena.com and add the same callback URL to Redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Groq: Ask AI in matches + AI pre-check on community submissions (advisory only)
GROQ_API_KEY=

# Service role: recommended so AI pre-check can update submissions after insert
SUPABASE_SERVICE_ROLE_KEY=
